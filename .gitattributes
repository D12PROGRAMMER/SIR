# Keep line endings sane cross-platform. Executable text stays LF so shell
# scripts and Rust/Python sources don't get CRLF shebangs that fail on Linux.
* text=auto eol=lf
*.rs   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.html text eol=lf
*.js   text eol=lf
